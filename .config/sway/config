# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
#set $term kitty
exec foot -s
set $term footclient
set $term_float footclient -e
# Your preferred application launcher
# Note: pass the final command to swaymsg so that the resulting window can be opened
# on the original workspace that the command was run on.
#set $menu dmenu_path | dmenu | xargs swaymsg exec --

xwayland enable

# styles - set the folder for your theme defination file
set $theme .config/sway/macha-green

#theme variables
#include $theme/definitions

# mako
exec mako --text-color "#ffffff" --border-color "#50efa0" --background-color "#303030" --border-size 3 --width 400 --height 200 --padding 20 --margin 20 --default-timeout 15000
#exec_always mako --text-color "$text-color" --border-color "$accent-color" --background-color "$background-color" --border-size 3 --width 400 --height 200 --padding 20 --margin 20 --default-timeout 15000

# rofi
#set $menu wofi --show drun
set $menu rofi -show drun -theme .config/rofi/custom.rasi -display-drun "Run"

# Pulseaudio Config
set $pulseaudio pavucontrol

### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
#output * bg /usr/share/backgrounds/sway/Sway_Wallpaper_Blue_1366x768.png fill
output * bg ~/.wallpaper fill
#
# Example configuration:
#
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

# Monitor to the right
output eDP-1 resolution 1366x768 position 0,520
#output eDP-1 resolution 1366x768@60.016Hz position 0,0
output HDMI-A-1 resolution 1920x1080@75.025Hz position 1366,0
#output * adaptive_sync on

# Monitor to the left
#output eDP-1 resolution 1366x768 position 1920,520
#output HDMI-A-1 resolution 1920x1080 position 0,0

output * adaptive_sync on

